#!/bin/bash
#json='{'
root_folder="$HOME/mwtheus.github.io"
index_file='<ul>'

echo_items() {
  dir=$1; dir_name=$2

  for item in $dir/*; do
    if [[ -d $item ]]; then 
      dir_name="$(echo "${item##*/}")"

      if [[ ! -d "$root_folder/$dir_name" ]]; then
        mkdir "$root_folder/$dir_name" # CANT HANDLE NESTED
      fi

      echo_items $item $dir_name
    else
      ext="$(echo "$item" | cut -d '.' -f2)"
      file_name="$(echo "${item##*/}" | cut -d '.' -f1)"

      if [[ "$ext" == "md" || "$ext" == "txt" ]]; then

        inner_html="
        <html>

        <head>
          <title>mwtheus < $name</title>
          <meta charset=\"UTF-8\">
          <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">
          <meta name=\"viewport\" 
            content=\"width=device-width, initial-scale=1.0\">
          <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">
          <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>
          <link rel=\"stylesheet\"
            href=\"https://fonts.googleapis.com/css2?family=Alegreya+Sans+SC:wght@300&display=swap\">
          <link rel=\"stylesheet\" href=\"../styles.css\" />
        </head>

        <body>
          <header><a href=\"/\">mwtheus</a></header>

          <article>
            $(pandoc $item)
          </article>
        </body>

        </html>"

        echo "$inner_html" > "$root_folder/$dir_name/$file_name.html"
        index_file+="
        <li>
          <a href=\"$root_folder/$dir_name/$file_name.html\">
            $root_folder/$dir_name/$file_name.html
          </a>
        </li>"
      elif [[ "$ext" == "csv" ]]; then
        has_header=0
        inner_html="
        <html>

        <head>
          <title>mwtheus < $name</title>
          <meta charset=\"UTF-8\">
          <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">
          <meta name=\"viewport\" 
            content=\"width=device-width, initial-scale=1.0\">
          <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">
          <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>
          <link rel=\"stylesheet\"
            href=\"https://fonts.googleapis.com/css2?family=Alegreya+Sans+SC:wght@300&display=swap\">
          <link rel=\"stylesheet\" href=\"../styles.css\" />
        </head>

        <body>
          <header><a href=\"/\">mwtheus</a></header>

          <article>
            <table>"

        while IFS="" read -r line || [ -n "$line" ]
        do
          if [[ $has_header -eq 0 ]]; then
            has_header=1
            inner_html+='<thead><tr>'

            readarray -d , -t values <<< "$line"
            for value in ${values[@]}; do
              inner_html+="<th>$value</th>"
            done

            inner_html+='</tr></thead><tbody>'
          else
            inner_html+='<tr>'

            readarray -d , -t values <<< "$line"
            for ((n=0; n < ${#values[*]}; n++)); do
              inner_html+="<td>${values[n]}</td>"
            done

            inner_html+='</tr>'
          fi
        done < $item

        inner_html+="
              </tbody>
            </table>
          </article>
        </body>

        </html>"

        echo "$inner_html" > "$root_folder/$dir_name/$file_name.html"

        index_file+="
        <li>
          <a href=\"$root_folder/$dir_name/$file_name.html\">
            $root_folder/$dir_name/$file_name.html
          </a>
        </li>"
 
      else
        continue ## NEEDS TO BE PARSED LINE BY LINE
      fi
    fi
  done
}

echo_items "$HOME/data" ''
echo "$index_file</ul>" > "$root_folder/index.html"
