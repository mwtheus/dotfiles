#!/bin/bash

URL='https://www.spacetelescope.org/images/heic0105a/'

get_data() {
  curl -s "$URL" | grep "$1" | sed -E 's/<a*\/a>/oi/g' | sed -E 's/<[^<>]*>//g' | sed 's/^ *//'
}

#printf "Getting title...\n"
#curl -s "$URL" | grep '<h1>' | sed -E 's/<[^<>]*>//g'

printf "\nGetting article...\n"
curl -s "$URL" | grep '<p>' | sed -e 's/<a.*a>/oi/'
