#!/bin/bash

if [[ -z "$1" ]]; then exit; fi

if [[ "$1" == "--list" || "$1" == "-l" ]];
then
  aliases=$(cat $HOME/.files/etc/sshs | cut -d ',' -f1)
  echo ${aliases[@]}
  exit
fi

alias=$1
user=$(cat $HOME/.files/etc/sshs | grep $alias | cut -d ',' -f2)
address=$(cat $HOME/.files/etc/sshs | grep $alias | cut -d ',' -f3)
password=$(cat $HOME/.files/etc/sshs | grep $alias | cut -d ',' -f4)

echo $password | xclip -i
ssh $user@$address
